#! /usr/bin/env janet

(use dotenv)

(def clean_arg
  (get (dyn :args) 1))

(defn clean-build []
  (print "cleaning")
    (os/execute @["jpm" "clean"] :p))


(if (= clean_arg "clean")
  (clean-build))

(if (not= (os/stat "./test.db") nil)
    (os/rm "./test.db"))

(os/execute @["jpm" "build"] :p)


(import ./tests/in_memory_db_tests :as memory-test)
(import ./tests/in_file_db_tests :as file-test)

(print "...")

(memory-test/execute-in-memory-test)

(file-test/execute-in-file-test)

(print "...")

(print "ENDING TEST")
