#! /usr/bin/env janet

(print "Running Tests")

(if (not= (os/stat "./test.db") nil)  
  (os/rm "./test.db"))
(os/execute @["jpm" "clean"] :p)
(os/execute @["jpm" "build"] :p)

(import ./build/hydra)

(def local-db
  (hydra/open-local-db ":memory:"))

(hydra/execute local-db "select 1" @[])

(def test-db
  (hydra/open-local-db "./test.db"))

(hydra/execute test-db "select 1" @[])

(print "Finished Running Tests")
